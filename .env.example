# Server
APPLICATION_NAME=SMUS-SERVER
PORT=1199
# SERVER_IP=127.0.0.1
ENVIRONMENT=development

# Network
MAX_MESSAGE_SIZE=2097151
TCP_NO_DELAY=1
DEFAULT_USER_LEVEL=20

# Logging
LOGGER_TYPE=file
LOG_LEVEL=DEBUG
LOG_PATH=logs

# Encryption
CIPHER_TYPE=blowfish
ENCRYPTION_KEY=IPAddress resolution

# Protocol
PROTOCOL=smus

# Database
DATABASE_TYPE=sqlite
DATABASE_PATH=data/musgo.db

# Scripting
SCRIPTS_PATH=external/scripts
SCRIPT_TIMEOUT=5

# Authentication (none, open, strict)
AUTH_MODE=open

# Session Store (memory or redis)
SESSION_STORE_TYPE=memory
# Redis settings (only used when SESSION_STORE_TYPE=redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=musgo
REDIS_CONN_TTL=3600

# Message Queue (memory, redis, rabbitmq)
QUEUE_TYPE=memory
# Queue Redis settings (only used when QUEUE_TYPE=redis)
QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=
QUEUE_REDIS_DB=1
QUEUE_REDIS_KEY_PREFIX=musgoq
# RabbitMQ settings (only used when QUEUE_TYPE=rabbitmq)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=musgo
