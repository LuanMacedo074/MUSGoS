# Server
APPLICATION_NAME=SMUS-SERVER
PORT=1199
# SERVER_IP=127.0.0.1
ENVIRONMENT=development

# Network
MAX_MESSAGE_SIZE=2097151
TCP_NO_DELAY=1
DEFAULT_USER_LEVEL=20

# Logging
LOGGER_TYPE=file
LOG_LEVEL=DEBUG
LOG_PATH=logs

# Encryption
CIPHER_TYPE=blowfish
ENCRYPTION_KEY=key

# Protocol
PROTOCOL=smus

# Database
DATABASE_TYPE=sqlite
DATABASE_PATH=data/musgo.db

# Scripting
SCRIPTS_PATH=external/scripts
SCRIPT_TIMEOUT=5

# Authentication (none, open, strict)
AUTH_MODE=open

# Session Store (memory or redis)
SESSION_STORE_TYPE=memory
# Redis settings (only used when SESSION_STORE_TYPE=redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=musgo
REDIS_CONN_TTL=3600
