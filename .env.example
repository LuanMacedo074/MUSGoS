# Server
APPLICATION_NAME=SMUS-SERVER
PORT=1199
# SERVER_IP=127.0.0.1
ENVIRONMENT=development

# Network
MAX_MESSAGE_SIZE=2097151
TCP_NO_DELAY=1
DEFAULT_USER_LEVEL=20

# Logging
LOGGER_TYPE=file
LOG_LEVEL=DEBUG
LOG_PATH=logs
LOG_BUFFER_SIZE=1024

# Encryption
CIPHER_TYPE=blowfish
# Prefix key with "#All" to encrypt full packets (header+body) in both directions.
# Without "#All", only the Logon content is encrypted client→server.
ENCRYPTION_KEY=IPAddress resolution

# Protocol
PROTOCOL=smus

# Database
DATABASE_TYPE=sqlite
DATABASE_PATH=data/musgo.db

# Scripting
SCRIPTS_PATH=external/scripts
SCRIPT_TIMEOUT=5

# Authentication (none, open, strict)
AUTH_MODE=open

# Session Store (memory or redis)
SESSION_STORE_TYPE=memory
# Redis settings (only used when SESSION_STORE_TYPE=redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=musgo
REDIS_CONN_TTL=3600

# Message Queue (memory, redis, rabbitmq)
QUEUE_TYPE=memory
# Queue Redis settings (only used when QUEUE_TYPE=redis)
QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=
QUEUE_REDIS_DB=1
QUEUE_REDIS_KEY_PREFIX=musgoq
# RabbitMQ settings (only used when QUEUE_TYPE=rabbitmq)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=musgo

# Cache (memory or redis)
CACHE_TYPE=memory
# Cache Redis settings (only used when CACHE_TYPE=redis)
CACHE_REDIS_HOST=localhost
CACHE_REDIS_PORT=6379
CACHE_REDIS_PASSWORD=
CACHE_REDIS_DB=2
CACHE_REDIS_KEY_PREFIX=musgoc

# Idle Check (seconds, 0 = disabled)
IDLE_TIMEOUT=0

# UDP Server (optional, empty = disabled)
UDP_PORT=

# UserLevel per command (override defaults)
# Format: USERLEVEL_<SUBJECT_WITH_DOTS_AS_UNDERSCORES>=<level>
# USERLEVEL_SYSTEM_USER_DELETE=80
# USERLEVEL_DBADMIN_CREATEUSER=80
# USERLEVEL_SYSTEM_SERVER_GETVERSION=20
# USERLEVEL_SYSTEM_SERVER_SETKILLTIMER=80
# USERLEVEL_SYSTEM_SERVER_CANCELKILLTIMER=80
# USERLEVEL_SYSTEM_USER_SETKILLTIMER=80
# USERLEVEL_SYSTEM_USER_CANCELKILLTIMER=80
# USERLEVEL_SYSTEM_SERVER_SENDEMAIL=80
